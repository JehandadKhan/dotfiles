# ~/.bashrc: executed by bash(1) for non-login shells.
# see /usr/share/doc/bash/examples/startup-files (in the package bash-doc)
# for examples

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# append to the history file, don't overwrite it
shopt -s histappend

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize

# If set, the pattern "**" used in a pathname expansion context will
# match all files and zero or more directories and subdirectories.
#shopt -s globstar

# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# set variable identifying the chroot you work in (used in the prompt below)
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

# set a fancy prompt (non-color, unless we know we "want" color)
case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

# uncomment for a colored prompt, if the terminal has the capability; turned
# off by default to not distract the user: the focus in a terminal window
# should be on the output of commands, not on the prompt
#force_color_prompt=yes

if [ -n "$force_color_prompt" ]; then
    if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
	# We have color support; assume it's compliant with Ecma-48
	# (ISO/IEC-6429). (Lack of such support is extremely rare, and such
	# a case would tend to support setf rather than setaf.)
	color_prompt=yes
    else
	color_prompt=
    fi
fi

if [ "$color_prompt" = yes ]; then
    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w\$ '
fi
unset color_prompt force_color_prompt

# If this is an xterm set the title to user@host:dir
case "$TERM" in
xterm*|rxvt*)
    PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
    ;;
*)
    ;;
esac

# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    #alias dir='dir --color=auto'
    #alias vdir='vdir --color=auto'

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# colored GCC warnings and errors
#export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# some more ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# Add an "alert" alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# Alias definitions.
# You may want to put all your additions into a separate file like
# ~/.bash_aliases, instead of adding them here directly.
# See /usr/share/doc/bash-doc/examples in the bash-doc package.

if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# enable programmable completion features (you don't need to enable
# this, if it's already enabled in /etc/bash.bashrc and /etc/profile
# sources /etc/bash.bashrc).
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# Mount /etc/passwd + /etc/group read-only so the host UID/GID (1000) resolves
# to the real username/groups inside the container (whoami, getpwuid, NSS all
# work). This also makes Bazel pick the same output base
# (~/.cache/bazel/_bazel_$USER) as the host and reuse the warm repo cache
# instead of re-downloading toolchains (e.g. LLVM). -e USER="$USER" is kept as
# a belt-and-suspenders fallback.
#
# GPU access (ROCm): the device nodes are group-owned on the host as
#   /dev/kfd          -> render   <- rocminfo opens this
#   /dev/dri/renderD* -> render
#   /dev/dri/card*    -> video
# so we --group-add the OWNING GIDs, derived at runtime via `stat -c %g` rather
# than hardcoded. `video` is a static GID (44) but `render` is dynamically
# allocated (109 here, but per-host), so name-based `--group-add video` misses
# render and breaks rocminfo, and hardcoded numerics aren't portable.
#
# This file is a chezmoi template: the GPU flags are emitted only when /dev/kfd
# exists at `chezmoi apply` time, so a CPU-only box gets a plain drun with no
# --device/--group-add and never runs `stat` on a missing node. On a GPU box the
# runtime `$(stat ...)` still resolves the render GID fresh each invocation, so
# it self-corrects even if the GID changes without a re-apply.
#
# Python isolation: because we bind-mount $HOME onto the container's $HOME, the
# host's `pip install --user` tree (~/.local/lib/pythonX.Y/site-packages, plus
# ~/.local/bin which is on PATH) leaks into every container interpreter via
# Python's automatic user-site. That shadows/contaminates venvs built inside
# the container. We neutralize it without un-mounting $HOME:
#   PYTHONNOUSERSITE=1      -> Python ignores ~/.local/lib user-site entirely
#   PIP_USER=0              -> `pip install` never prefers/writes ~/.local
#   PIP_REQUIRE_VIRTUALENV=1 -> pip refuses to install outside an active venv
# Build container venvs as usual (`python -m venv .venv && . .venv/bin/activate`)
# and they stay insulated from the host ~/.local.
{{- if stat "/dev/kfd" }}
alias drun='docker run -it -u "$(id -u):$(id -g)" -v "$HOME:$HOME" -w "$HOME" -e HOME="$HOME" -e USER="$USER" -e PYTHONNOUSERSITE=1 -e PIP_USER=0 -e PIP_REQUIRE_VIRTUALENV=1 -v /etc/passwd:/etc/passwd:ro -v /etc/group:/etc/group:ro --network=host --device=/dev/kfd --device=/dev/dri --group-add "$(stat -c %g /dev/kfd)" --group-add "$(stat -c %g /dev/dri/renderD128)" --cap-add=SYS_PTRACE --security-opt seccomp=unconfined -v $HOME:/data --shm-size=64G'
{{- else }}
# No /dev/kfd on this host (CPU-only): drun without GPU device/group flags.
alias drun='docker run -it -u "$(id -u):$(id -g)" -v "$HOME:$HOME" -w "$HOME" -e HOME="$HOME" -e USER="$USER" -e PYTHONNOUSERSITE=1 -e PIP_USER=0 -e PIP_REQUIRE_VIRTUALENV=1 -v /etc/passwd:/etc/passwd:ro -v /etc/group:/etc/group:ro --network=host --cap-add=SYS_PTRACE --security-opt seccomp=unconfined -v $HOME:/data --shm-size=64G'
{{- end }}

# carbonyl uses an ephemeral profile by default — pin --user-data-dir so
# cookies, logins, and history survive restarts.
alias carbonyl='carbonyl --user-data-dir="$HOME/.local/share/carbonyl-profile"'

# Add ~/.local/bin to PATH (for Claude Code)
export PATH="$HOME/.local/bin:$PATH"

[ -f "$HOME/.fzf.bash" ] && source "$HOME/.fzf.bash"

# CLI shell completions (terraform / gh / chezmoi). Each tool ships its
# own completion: terraform uses Cobra's `complete -C` self-completion
# mechanism (the binary acts as its own completion script when invoked
# with COMP_LINE set); gh and chezmoi print a bash completion script via
# their `completion bash` subcommand. The `terraform -install-autocomplete`
# / `gh completion --install` flows would do the same but write directly
# into ~/.bashrc, which fights chezmoi — so we wire them up explicitly
# here, gated on presence so an unused shell on a fresh box doesn't error.
command -v terraform >/dev/null 2>&1 && complete -C "$(command -v terraform)" terraform
command -v gh        >/dev/null 2>&1 && eval "$(gh completion -s bash)"
command -v chezmoi   >/dev/null 2>&1 && eval "$(chezmoi completion bash)"
command -v doctl     >/dev/null 2>&1 && eval "$(doctl completion bash)"
command -v kubectl   >/dev/null 2>&1 && eval "$(kubectl completion bash)"

# starship prompt — overrides the PS1 block above when installed.
# Falls back silently to the stock PS1 if starship isn't on PATH.
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init bash)"
fi
